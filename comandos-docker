
docker build --> usado para criar uma imagem Docker a partir de um Dockerfile --- docker build -t lucasrm/allbooks:1.1 .
    -t --> Define nome/tag da imagem --- docker build -t app:v1 .
    -f --> Define Dockerfile customizado. --- docker build -f Dockerfile.dev .
    --no-cache --> Ignora cache de layers --- docker build --no-cache .
    --build-arg --> Passa variáveis para build --- docker build --build-arg VERSION=1.0 .
    -q --> Saída silenciosa --- docker build -q .
    --pull --> Força download da imagem base mais recente --- docker build --pull .

docker container --> Ele faz parte da sintaxe mais moderna do Docker. Exemplo:
    Sintaxe antiga	    Sintaxe moderna
    docker ps	          docker container ls
    docker rm	          docker container rm
    docker stop	        docker container stop
    docker inspect	    docker container inspect
  
docker exec -it [CONTAINER ID] /bin/bash --> Entrar no container

docker history --> mostra o histórico de camadas (layers) de uma imagem Docker --- docker history [ID IMAGE]

docker images --> Listar as imagens locais

docker inspect [ID...] --> Exibir informações detalhadas de objetos do Docker em formato JSON.
  Pode analisar containers / imagens / volumes / redes / serviços

docker login --> Autenticar o Docker em um registry de imagens
    docker login registry.empresa.com --> Login em registry privado
    
docker logs [CONTAINER ID] --> Ver logs

docker pause [CONTAINER ID] --> Ele irá pausar o meu container
docker unpause [CONTAINER ID] --> Ele irá despausar o meu container

docker pull [imagem] --> Ele faz apenas o download dessa imagem

docker push --> Usado para enviar uma imagem Docker local para um registry/repositório remoto
    docker push marcelo/app:v1 --> Exemplo simples
    docker push registry.empresa.com/app:v1 --> Push para registry privado

docker ps --> Exibe os contêineres em execução
  -a --> mostra containers ativos / parados / encerrados / com erro / criados mas nunca iniciados --- docker ps -a
  -q --> Mostra apenas os IDs dos containers. --- docker ps -q

docker rm [CONTAINER ID] --> Remove um container
  --force --> Força a remoção do container

docker run [OPÇÕES] [contêiner] [COMANDO] --> Executa um contêiner
  --help --> Ver todas as opções disponíveis --- docker run --help
  -d --> detached, roda em segundo plano --- docker run -d nginx
  --name --> Definir nome do container --- docker run --name web01 nginx
  -p 8080:80 --> Mapear portas (Formato: PORTA_HOST:PORTA_CONTAINER) --- docker run -p 8080:80 nginx
  -P --> publicar automaticamente todas as portas expostas pelo container em portas aleatórias do host. --- docker run -d -P docker/example-voting-app-vote
  -it --> Executar terminal interativo --- docker run -it ubuntu /bin/bash
      -i --> interativo
      -t --> terminal TTY
  --rm --> Remover automaticamente ao sair (Container é apagado ao finalizar.) --- docker run --rm ubuntu
  -v --> Montar volume/diretório (Formato: HOST:CONTAINER) --- docker run -v /dados:/app nginx
  -e --> Definir variável de ambiente --- docker run -e MYSQL_ROOT_PASSWORD=senha mysql
  --network minha_rede --> Conectar em rede específica --- docker run --network minha_rede nginx
  -m 512m --> Limitar memória --- docker run -m 512m nginx
  --cpus="1.5" --> Limitar CPU --- docker run --cpus="1.5" nginx
  --restart always --> Reinício automático --- docker run --restart always nginx
      Outras opções:
        no
        on-failure
        unless-stopped
  --hostname --> Definir hostname --- docker run --hostname servidor01 ubuntu
  -u --> Rodar como usuário específico --- docker run -u 1000 ubuntu / docker run -u marcelo ubuntu
  -w --> Definir diretório de trabalho --- docker run -w /app ubuntu
  Executar comando customizado --- docker run ubuntu ls -l /
  Exemplos reais
    docker run -d --name nginx01 -p 80:80 nginx --> Subir um NGINX web
    docker run -it ubuntu /bin/bash --> Abrir shell Ubuntu
    docker run -d --name mysql01 -e MYSQL_ROOT_PASSWORD=Senha123 -p 3306:3306 mysql:8Banco MySQL --> Banco MySQL

docker start [CONTAINER ID] --> Iniciar container

docker stop [CONTAINER ID] --> Parar container
  -t=0 --> parar de imediato meu container
  $(docker container ls -q) --> 

docker tag --> Usado para criar uma nova tag (apelido/referência) para uma imagem Docker existente
    docker tag nginx meu-nginx:v1 --> Exemplo simples
    docker tag app:v1 registry.empresa.com/dev/app:v1 --> Exemplo com registry privado






